# syntax=docker/dockerfile:1.7
#
# twarc web — Next.js 16 standalone build.
# Three stages: deps install → build → minimal runtime.
# Final image is ~150 MB (vs ~800 MB with full node_modules).

# -------- 1. Dependency install --------
FROM node:26-alpine AS deps
RUN npm install -g pnpm@11
WORKDIR /repo

# Copy lockfiles first for cache hits.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/

# --config.dangerouslyAllowAllBuilds=true: pnpm 10+ refuses to run
# postinstall scripts by default; sharp + unrs-resolver need theirs to
# fetch their native binaries. Equivalent to running `pnpm approve-builds`
# interactively. Safe in our image because we control the lockfile.
RUN pnpm install --frozen-lockfile --filter web... \
    --config.dangerouslyAllowAllBuilds=true

# -------- 2. Build --------
FROM node:26-alpine AS builder
RUN npm install -g pnpm@11
WORKDIR /repo

COPY --from=deps /repo ./
COPY apps/web ./apps/web

# Build-time API URL — empty string keeps browser fetches relative ("/api/me"),
# which the Caddy front-door routes to the API container on the same origin.
# Override with --build-arg only if you're serving the API on a *different* domain.
ARG NEXT_PUBLIC_API_URL=
ARG INTERNAL_API_URL=http://api
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    INTERNAL_API_URL=$INTERNAL_API_URL \
    NEXT_TELEMETRY_DISABLED=1

# SITE_URL is intentionally read at *runtime* by lib/site.ts so the same image
# works on any deployer's domain — no rebuild needed.

RUN pnpm --filter web build

# -------- 3. Runtime --------
FROM node:26-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Non-root runtime user.
RUN addgroup -S -g 1001 nodejs \
    && adduser -S -u 1001 -G nodejs nextjs

# Next.js standalone output bundles only what's needed.
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD wget -q --spider http://127.0.0.1:3000/ || exit 1

CMD ["node", "apps/web/server.js"]
