# syntax=docker/dockerfile:1.7
#
# twarc web — Next.js 16 standalone build.
# Three stages: deps install → build → minimal runtime.
# Final image is ~150 MB (vs ~800 MB with full node_modules).

# -------- 1. Dependency install --------
FROM node:22-alpine AS deps
RUN corepack enable pnpm
WORKDIR /repo

# Copy lockfiles first for cache hits.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile --filter web...

# -------- 2. Build --------
FROM node:22-alpine AS builder
RUN corepack enable pnpm
WORKDIR /repo

COPY --from=deps /repo ./
COPY apps/web ./apps/web

ARG NEXT_PUBLIC_API_URL=
ARG INTERNAL_API_URL=http://api
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    INTERNAL_API_URL=$INTERNAL_API_URL \
    NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter web build

# -------- 3. Runtime --------
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Non-root runtime user.
RUN addgroup -S -g 1001 nodejs \
    && adduser -S -u 1001 -G nodejs nextjs

# Next.js standalone output bundles only what's needed.
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD wget -q --spider http://127.0.0.1:3000/ || exit 1

CMD ["node", "apps/web/server.js"]
