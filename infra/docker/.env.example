# Copy to `.env` and generate fresh secrets for your environment.
# Both values below are arbitrary strings — Meilisearch uses MEILI_MASTER_KEY
# as its master API key; imgproxy uses the KEY/SALT pair to sign image URLs.
#
# Generate strong values (any of these works):
#   openssl rand -hex 32
#   head -c 32 /dev/urandom | xxd -p -c 256
#   python -c "import secrets; print(secrets.token_hex(32))"

MEILI_MASTER_KEY=
IMGPROXY_KEY=
IMGPROXY_SALT=
