## ───────────────────────────────────────────────────────────────
##  twarc — docker-compose.prod.yml environment template.
##
##  Copy to `.env` next to docker-compose.prod.yml and fill in the
##  required values. Everything marked `[required]` is enforced by
##  compose at startup — if it's missing, the stack won't boot.
## ───────────────────────────────────────────────────────────────

# ───────── Domain / TLS ─────────
# The full URL users will visit.            [required]
SITE_URL=https://twarc.example

# The bare hostname Caddy uses for automatic Let's Encrypt TLS.
# Set to `:80` to skip TLS (when behind another proxy that terminates it).
#                                            [required]
SERVER_NAME=twarc.example

# Cookie domain — must be the bare hostname (NOT prefixed with `.`).
SESSION_DOMAIN=twarc.example
SANCTUM_STATEFUL_DOMAINS=twarc.example

# Optional. If you front your media with a CDN, set its URL here.
# Defaults to `${SITE_URL}/storage` when empty.
CDN_URL=

# ───────── Secrets (generate fresh — never copy from anywhere) ─────────
# php -r 'echo "base64:" . base64_encode(random_bytes(32));'
APP_KEY=

# openssl rand -hex 32
DB_PASSWORD=
MEILI_MASTER_KEY=
IMGPROXY_KEY=
IMGPROXY_SALT=

# ───────── Database (defaults are fine) ─────────
DB_DATABASE=twarc
DB_USERNAME=twarc

# ───────── Search ─────────
# Leave `null` to skip Meilisearch indexing (catalog browse still works
# off Postgres). Set to `meilisearch` once issue #7 lands.
SCOUT_DRIVER=null

# ───────── Mail (optional; defaults to writing to logs) ─────────
# Set MAIL_MAILER=smtp + the rest once you wire a provider for
# password-reset + email-verification flows.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@twarc.example
MAIL_FROM_NAME=twarc
