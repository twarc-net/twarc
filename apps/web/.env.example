## ───────────────────────────────────────────────────────────────
##  twarc web (Next.js) — environment example
##  Copy to `.env.local` and fill in for your environment.
##  `.env.local` is gitignored — never commit secrets.
## ───────────────────────────────────────────────────────────────

# Public API base. In dev, point at your local Laravel:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
# In prod, this is your same domain (cookies must be same-site):
#   NEXT_PUBLIC_API_URL=https://twarc.net
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side fetch of the API for SSR + sitemaps. Bypasses public proxy.
# In dev:  http://127.0.0.1:8000
# In prod: http://127.0.0.1:8000 (Laravel running on the same box)
INTERNAL_API_URL=http://127.0.0.1:8000
