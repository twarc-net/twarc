## ───────────────────────────────────────────────────────────────
##  twarc API — Laravel environment example
##  Copy this file to `.env` and fill in the values for your env.
##  Never commit a real `.env` — it's in .gitignore for a reason.
## ───────────────────────────────────────────────────────────────

APP_NAME=twarc
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Public CDN base (Bunny / Cloudflare / etc.). Used by the front-end logo,
# OG images, and by image URLs in API responses.
CDN_URL=https://cdn.twarc.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ──────── Logging ────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────── Database ────────
# Production = Postgres 16+; dev can use sqlite for the quickstart.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=twarc
DB_USERNAME=twarc
DB_PASSWORD=

# ──────── Session / cache / queue ────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ──────── Redis (Horizon, cache, sessions) ────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────── Mail ────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@twarc.net"
MAIL_FROM_NAME="${APP_NAME}"

# ──────── Object storage (Backblaze B2 / S3-compatible) — optional ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────── Search (optional) ────────
# Meilisearch will be wired in a future release; safe to leave blank.
SCOUT_DRIVER=null
MEILISEARCH_HOST=
MEILISEARCH_KEY=

# ──────── Image processing (optional) ────────
# imgproxy for on-the-fly variants. Not required for dev.
IMGPROXY_URL=
IMGPROXY_KEY=

# ──────── GIF picker (optional) ────────
# Tenor/Giphy keys for the comment GIF picker. Skip if you don't need GIFs.
KLIPY_API_KEY=
GIPHY_API_KEY=

# ──────── Notifications (optional) ────────
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
